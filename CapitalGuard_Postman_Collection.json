         "name": "1. Authentication",
         "item": [
            {
               "name": "Register User",
               "request": {
                  "method": "POST",
                  "header": [
                     {
                        "key": "Content-Type",
                        "value": "application/json"
                     }
                  ],
                  "body": {
                     "mode": "raw",
                     "raw": "{\n    \"name\": \"Test User\",\n    \"email\": \"test@example.com\",\n    \"password\": \"password123\"\n}"
                  },
                  "url": {
                     "raw": "{{base_url}}/api/auth/register",
                     "host": [
                        "{{base_url}}"
                     ],
                     "path": [
                        "api",
                        "auth",
                        "register"
                     ]
                  }
               }
            },
            {
               "name": "Login",
               "request": {
                  "method": "POST",
                  "header": [
